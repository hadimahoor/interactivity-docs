{
    "name": "interactivity-docs/interactivity-docs",
    "description": "An interactive WordPress documentation plugin built with the Interactivity API.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "wordpress",
        "plugin",
        "interactivity-api",
        "documentation",
        "blocks"
    ],
    "authors": [
        {
            "name": "Hadi Khodayari",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "10up/wp_mock": "^0.5",
        "mockery/mockery": "^1.5",
        "squizlabs/php_codesniffer": "^3.10",
        "wp-cli/wp-cli": "^2.11"
    },
    "autoload": {
        "psr-4": {
            "InteractivityDocs\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.0.30"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "lint": "phpcs",
        "lint:fix": "phpcbf",   
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage"
    }
}
