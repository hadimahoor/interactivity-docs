{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "interactivity-docs/docs-archive",
  "version": "1.0.0",
  "title": "Docs Archive",
  "category": "widgets",
  "icon": "media-interactive",
  "description": "Interactive documents archive with advanced filtering.",
  "keywords": ["documents", "archive", "filter", "pagination"],
  "example": {},
  "supports": {
    "interactivity": true,
    "html": false
  },
  "textdomain": "interactivity-docs",
  "attributes": {
    "type":          { "type": "string",  "default": "paper"   },
    "itemsPerPage":  { "type": "integer", "default": 12        },
    "currentPage":   { "type": "integer", "default": 1         },
    "showMeta":      { "type": "boolean", "default": true      },
    "layout":        { "type": "string",  "default": "card"    },
    "columns":       { "type": "integer", "default": 3         },
    "sort":          { "type": "string",  "default": "latest"  },
    "status":        { "type": "string",  "default": "publish" },
    "related":       { "type": "boolean", "default": false     },
    "currentAuthor": { "type": "boolean", "default": false     },
    "authors":       { "type": "array",   "default": []        },
    "list":          { "type": "array",   "default": []        },
    "count":         { "type": "integer", "default": 0         },
    "year":          { "type": "array",   "default": ["-"]     },
    "language":      { "type": "array",   "default": ["-"]     },
    "magazine":      { "type": "array",   "default": ["-"]     },
    "paperType":     { "type": "array",   "default": ["-"]     },
    "bookType":      { "type": "array",   "default": ["-"]     },
    "publication":   { "type": "array",   "default": ["-"]     },
    "gender":        { "type": "array",   "default": ["-"]     },
    "tag":           { "type": "array",   "default": ["-"]     }
  },
  "editorScript":     "file:./index.js",
  "editorStyle":      "file:./index.css",
  "style":            "file:./style-index.css",
  "render":           "file:./render.php",
  "viewScriptModule": "file:./view.js"
}
